node_modules
dist

# Dev fixture artifacts — ignore everything in devFixtures except the harness fixtures
public/devFixtures/*
!public/devFixtures/fixture-elevation.json
!public/devFixtures/fixture-elevation.expected.json

# Un-ignore Claude Code local settings (permission modes only — no secrets)
# Negates the global git ignore rule (**/.claude/settings.local.json)
!.claude/settings.local.json

# Ignore Claude Code launch config — session-specific port bindings, not project state
.claude/launch.json
